---
	import Image from "astro/components/Image.astro"
	import me from "../images/me.webp";
---

<figure class="img--headshot">
	<Image src={me} alt="a quite handsome fella." width="360" height="360" loading="eager" />
</figure>

<style>
	.img--headshot {
		width: 100%;
		max-width: 15rem;
		height: auto;
		aspect-ratio: 1/1;
		position: relative;
		overflow: visible;
		border-radius: 50%;

		&::before {
			--follower-offset: .5rem;

			content: "";
			pointer-events: none;

			position: absolute;
			top: calc(var(--follower-offset) / -2);
			left: calc(var(--follower-offset) / -2);

			display: block;
			height: 100%;
			width: 100%;
			border-radius: 100%;

			background: var(--color-accent);
			transform: translateX(calc(var(--delta-x) * 1rem)) translateY(calc(var(--delta-y) * 1rem));
			transition: all var(--transition-time) linear;
		}

		&:hover, &:focus {
			&::before {
				height: calc(100% + var(--follower-offset));
				width: calc(100% + var(--follower-offset));
				transition-timing-function: ease;
				transform: none;
			}
		}

		img {
			border-radius: 50%;
			position: relative;
			z-index: 2;
			width: 100%;
		}
	}

	@media (max-width: 60rem) {
		.img--headshot {
			filter: drop-shadow(calc(0.5rem) calc(0.5rem) 0 var(--color-accent));
		}
	}

</style>

<script>
	import { getNormalizedDirection } from "@utils";

	window.addEventListener('DOMContentLoaded', () => {
		const headshot: HTMLDivElement | null =
			document.querySelector('.img--headshot')

		if (!headshot) return;

		initMouseFollower(headshot);
	});

	function initMouseFollower(headshot: HTMLDivElement) {
		// set up mouse-tracking box-shadow
        // track mouse position on move
        let mousePosition = { X: 0, Y: 0 }

        window.addEventListener('mousemove', (e) => {
            mousePosition.X = e.clientX
            mousePosition.Y = e.clientY
        })

        const headshotSize = headshot.offsetWidth
        const headshotHalfSize = headshotSize / 2

        function tickMouseFollower() {
			let headshotCenter = {
				X: headshot!.getBoundingClientRect().left + window.scrollX + headshotHalfSize,
				Y: headshot!.getBoundingClientRect().top + window.scrollY + headshotHalfSize
			}

            const delta = getNormalizedDirection(headshotCenter, mousePosition)

            // this custom property is used in CSS to control the box shadow
            headshot.style.setProperty('--delta-x', `${delta.x}`)
            headshot.style.setProperty('--delta-y', `${delta.y}`)
            headshot.style.setProperty('--dist', `${delta.distance}`)

            if (window.innerWidth > window.fontSize() * 60) {
				requestAnimationFrame(tickMouseFollower)
			}
        }

        // only tick this on desktop
        if (window.innerWidth > window.fontSize() * 60) {
            requestAnimationFrame(tickMouseFollower)
        }
	}
</script>