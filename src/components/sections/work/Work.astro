---
import { getEntry, render } from "astro:content";

import Frame from "../../../layouts/Frame.astro";
import Clients from "./clients/Clients.astro";
import Employers from "./employers/Employers.astro"

const work = await getEntry('sections', 'work');

if (!work) {
  throw new Error("Work entry not found");
}

const { Content } = await render(work);
---

<Frame id="section--work">
	<Content/>
	<hr>
	<Employers />
	<hr>
	<Clients />
</Frame>