---
import { getCollection } from "astro:content"
import ClientLogo from "./ClientLogo.astro";
const clients = await getCollection('clients')
---
<div id="clients">
	<h3>Selected Clients:</h3>
	<div class="client-logos">
		<ul>
			{clients.map((c: any) => {
				const { client_name, url, logo, logo_alt } = c.data

				return (

					<li>
						<ClientLogo clientName={client_name}
							clientUrl={url}
							logo={logo}
							logoAlt={logo_alt} />
					</li>
				)
			})}
		</ul>
	</div>
</div>

<style>
	.client-logos {
		margin-top: 2rem;

		ul {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 1rem;
			
			padding: 0;
			margin: 0;
			
			list-style: none;

			li {
				display: inline-flex;
				padding: 0;
				margin: 0;
			}

			a::after {
				display: none;
			}

			figure {
				position: relative;
			}

			figcaption {
				position: absolute;
				height: 1px;
				width: 1px;
				opacity: 0.001px;
				left: -100000px;
				top: -100000px;
			}

			img {
				margin: 0 auto;
				display: block;
				max-height: 5rem;
			}
		}
	}

	@media (max-width: 60rem) {
		.img--client-logo {
			width: 100%;
		}
	}
</style>

<script>
	import { shuffleDomNodeArray } from "@utils";

	window.addEventListener("DOMContentLoaded", () => {
		const clients = document.querySelector('#clients');
		const clientLogoList = document.querySelector('.client-logos ul');

		if (clients == null || clientLogoList == null) return;

		const clientLogoListItems = Array.from(document.querySelectorAll('.client-logos ul > li')) as Array<HTMLElement>;
		const newList = shuffleDomNodeArray(clientLogoListItems);

		clientLogoList.innerHTML = '';

		newList.forEach(i => {
			clientLogoList.appendChild(i);
		})

		clients.classList.add('initialized');
	})
</script>